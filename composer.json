{
  "name": "aiarmada/filament-inventory",
  "description": "Filament admin panel for inventory and warehouse management",
  "license": "MIT",
  "homepage": "https://github.com/aiarmada/commerce",
  "support": {
    "issues": "https://github.com/aiarmada/commerce/issues",
    "source": "https://github.com/aiarmada/commerce"
  },
  "require": {
    "aiarmada/inventory": "self.version",
    "filament/filament": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "AIArmada\\FilamentInventory\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AIArmada\\FilamentInventory\\FilamentInventoryServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
